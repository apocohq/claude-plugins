{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [{ "type": "command", "command": "python3 ~/.clawdboard/hooks/clawdboard-hook.py", "timeout": 10 }]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [{ "type": "command", "command": "python3 ~/.clawdboard/hooks/clawdboard-hook.py", "timeout": 10 }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [{ "type": "command", "command": "python3 ~/.clawdboard/hooks/clawdboard-hook.py", "timeout": 10 }]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [{ "type": "command", "command": "python3 ~/.clawdboard/hooks/clawdboard-hook.py", "timeout": 10 }]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [{ "type": "command", "command": "python3 ~/.clawdboard/hooks/clawdboard-hook.py", "timeout": 10 }]
